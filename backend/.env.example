# Example API Keys for SupplySense
# Copy this file to .env and fill in the values.

# Gemini API Key for NL understanding
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Claude API Key if using Anthropic models instead
CLAUDE_API_KEY=your_claude_api_key_here

# Database path (default: supplysense.db)
DATABASE_PATH=supplysense.db
